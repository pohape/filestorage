{
    email example@example.com
}

# vladivostok.<BASE_DOMAIN> -> <DATA_DIR>/vladivostok
vladivostok.example.com {
    reverse_proxy 127.0.0.1:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# vse.<BASE_DOMAIN> -> <DATA_DIR>/vse
vse.example.com {
    reverse_proxy 127.0.0.1:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# dina.<BASE_DOMAIN> -> <DATA_DIR> root (admin, Basic Auth enforced by Apache)
dina.example.com {
    reverse_proxy 127.0.0.1:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
